# Server-only secrets — set these in Vercel project env vars (all environments)
# and in .env for local dev. NEVER commit real values and never prefix with VITE_
# (VITE_ vars are inlined into the public browser bundle).

# Supabase project URL (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase service role key (Dashboard → Project Settings → API Keys).
# Full-access key, bypasses Row Level Security — server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
